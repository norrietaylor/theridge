---
import RidgeMark from './RidgeMark.astro';
import ThemePicker from './ThemePicker.astro';
import { NAV, HEADER_CTA } from '../consts';
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isCurrent = (href: string) => (href === '/' ? path === '/' : path === href || path.startsWith(href + '/'));
---
<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="Our Ridge, home">
      <RidgeMark height={40} />
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle" />

    <div class="header-right">
      <nav class="site-nav" aria-label="Primary">
        <ul>
          {NAV.map((item) => (
            <li>
              <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>{item.label}</a>
            </li>
          ))}
          <li class="nav-cta"><a href={HEADER_CTA.href} class="btn btn-primary">{HEADER_CTA.label}</a></li>
        </ul>
      </nav>

      <ThemePicker />

      <label for="nav-toggle" class="nav-burger" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </label>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: var(--c-paper);
    background: color-mix(in srgb, var(--c-paper) 90%, transparent);
    backdrop-filter: saturate(1.1) blur(6px);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    min-height: 68px;
  }
  .brand { display: inline-flex; text-decoration: none; color: var(--heading); }
  .header-right { display: flex; align-items: center; gap: var(--space-3); }
  .site-nav ul {
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin: 0;
    padding: 0;
  }
  .site-nav a {
    color: var(--c-cedar);
    text-decoration: none;
    font-weight: 600;
    font-size: var(--fs-sm);
    white-space: nowrap;
  }
  .site-nav a[aria-current='page'] { color: var(--c-clay-ink); text-decoration: underline; }
  .site-nav a:hover { color: var(--c-clay-ink); }
  .nav-cta a { color: var(--c-on-clay); }
  .nav-toggle, .nav-burger { display: none; }

  @media (max-width: 1200px) {
    .nav-burger {
      display: inline-flex;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      width: 44px;
      height: 44px;
      cursor: pointer;
    }
    .nav-burger span {
      height: 2.5px;
      width: 24px;
      background: var(--heading);
      border-radius: 2px;
      margin-inline: auto;
    }
    .site-nav {
      display: none;
      position: absolute;
      left: 0;
      right: 0;
      top: 100%;
      background: var(--c-paper);
      border-bottom: 1px solid var(--border);
      padding: var(--space-2) var(--space-3) var(--space-3);
    }
    .site-nav ul { flex-direction: column; align-items: stretch; gap: var(--space-2); }
    .nav-toggle:checked ~ .header-right .site-nav { display: block; }
    .nav-cta a { display: inline-block; }
  }
</style>
