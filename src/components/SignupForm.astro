---
import { SITE } from '../consts';
// Newsletter signup. Ships in a "not-yet-wired" state: until the MailerLite
// endpoint/keys exist, it posts nowhere and instead shows a graceful mailto
// fallback so neighbours are never met with a broken button.
// When MailerLite is connected (fast-follow), set MAILERLITE_ACTION and switch
// `wired` to true (or drive it from an env/config value).
interface Props {
  variant?: 'inline' | 'panel';
  heading?: string;
  blurb?: string;
  source?: string; // e.g. "home", "join", "flyer" — for later attribution
}
const {
  variant = 'panel',
  heading = 'Get Ridge news & events by email',
  blurb = 'A friendly monthly note — events, walks and rides, and issues before the City. No spam, unsubscribe anytime.',
  source = 'site',
} = Astro.props;

const wired = false; // flip to true once MailerLite is connected
const mailto = `mailto:${SITE.email}?subject=${encodeURIComponent('Please add me to The Ridge mailing list')}&body=${encodeURIComponent('Name:\nStreet (optional):\nEmail:\n\n(You can also tell us which activities interest you — dog walks, people walks, bike rides, events, or the voice-to-the-City group.)')}`;
---
<div class:list={['signup', variant === 'panel' ? 'panel-forest' : 'signup-inline']}>
  <div class="signup-copy">
    <h3>{heading}</h3>
    <p class={variant === 'panel' ? '' : 'muted'}>{blurb}</p>
  </div>

  <form class="signup-form" action={wired ? '/api/subscribe' : undefined} method="post" novalidate>
    <input type="hidden" name="source" value={source} />
    <div class="signup-row">
      <label class="visually-hidden" for={`su-name-${source}`}>Your name</label>
      <input id={`su-name-${source}`} name="name" type="text" placeholder="Your name" autocomplete="name" />
      <label class="visually-hidden" for={`su-email-${source}`}>Email address</label>
      <input id={`su-email-${source}`} name="email" type="email" required placeholder="you@email.com" autocomplete="email" />
      {wired
        ? <button type="submit" class="btn btn-primary">Join</button>
        : <a class="btn btn-primary" href={mailto}>Email to join</a>}
    </div>
    {!wired && (
      <p class="form-note" style="margin-top:.5rem">
        Online signup is coming soon — for now, tap <strong>Email to join</strong> and we’ll add you by hand.
        Prefer paper? Grab the <a href="/outreach">printable sign-up sheet</a>.
      </p>
    )}
  </form>
</div>

<style>
  .signup-inline { border: 1px solid var(--border); border-radius: var(--radius-lg); padding: var(--space-4); background: var(--surface); }
  .signup-copy h3 { margin-bottom: var(--space-1); }
  .signup-row { display: flex; gap: var(--space-2); flex-wrap: wrap; margin-top: var(--space-2); }
  .signup-row input { flex: 1 1 12rem; }
  .signup-row .btn { flex: 0 0 auto; }
  .panel-forest .form-note { color: #d7ddd0; }
  .panel-forest input { border-color: transparent; }
</style>
