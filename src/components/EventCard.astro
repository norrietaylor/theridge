---
import { monthAbbr, dayNum, formatLong } from '../lib/dates';

interface Props {
  href: string;
  title: string;
  start: Date;
  time?: string;
  location?: string;
  summary?: string;
  example?: boolean;
  image?: string;
  imageAlt?: string;
}
const { href, title, start, time, location, summary, example, image, imageAlt } = Astro.props;
---
<article class="event-card card">
  <a href={href} class="event-link">
    {image && (
      <span class="event-media">
        <img src={image} alt={imageAlt || ''} loading="lazy" />
      </span>
    )}
    <span class="event-row">
      <span class="datechip" aria-hidden="true">
        <span class="m">{monthAbbr(start)}</span>
        <span class="d">{dayNum(start)}</span>
      </span>
      <span class="event-body">
        <h3 class="event-title">{title}{example && <span class="ecard-badge">Suggested</span>}</h3>
        <p class="event-meta muted">
          <span>{formatLong(start)}</span>
          {time && <span> · {time}</span>}
          {location && <span> · {location}</span>}
        </p>
        {summary && <p class="event-summary">{summary}</p>}
      </span>
    </span>
  </a>
</article>

<style>
  .event-card { padding: var(--space-2); }
  .event-link { display: flex; flex-direction: column; gap: var(--space-2); text-decoration: none; color: inherit; }
  .event-row { display: flex; gap: var(--space-2); align-items: flex-start; }
  .event-media {
    display: block;
    margin: calc(var(--space-2) * -1) calc(var(--space-2) * -1) 0;
    border-radius: var(--radius) var(--radius) 0 0;
    overflow: hidden;
  }
  .event-media img { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; }
  .event-title { margin: 0 0 0.15rem; font-size: var(--fs-lg); }
  .ecard-badge {
    display: inline-block;
    margin-left: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    vertical-align: middle;
    padding: 0.15em 0.55em;
    border-radius: var(--radius-pill);
    background: var(--c-fern);
    color: var(--c-chip-ink);
  }
  .event-meta { margin: 0 0 0.3rem; font-size: var(--fs-sm); }
  .event-summary { margin: 0; }
  .event-link:hover .event-title { color: var(--c-clay-ink); }
</style>
