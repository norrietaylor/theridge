---
// The Ridge — community wordmark. A layered ridge-line motif + wordmark.
// Themeable: the ink uses `currentColor` (so it follows the surrounding text
// colour and the light/dark theme), and the sun uses the --c-fern token.
// Props:
//   variant: 'dark' (default — inherits the parent text colour) | 'light' (forced white, for dark backgrounds)
//   showText: include the "THE RIDGE" wordmark (default true)
//   height: pixel height of the lockup (default 40)
interface Props {
  variant?: 'dark' | 'light';
  showText?: boolean;
  height?: number;
  class?: string;
}
const { variant = 'dark', showText = true, height = 40, class: cls } = Astro.props;
const width = showText ? Math.round(height * 4.6) : height;
const forceWhite = variant === 'light';
---
<span
  class:list={['ridge-mark', cls]}
  style={`display:inline-flex;align-items:center;height:${height}px${forceWhite ? ';color:#fff' : ''}`}
  aria-hidden="true"
>
  <svg width={width} height={height} viewBox={showText ? '0 0 230 50' : '0 0 50 50'} fill="none" xmlns="http://www.w3.org/2000/svg" role="img">
    <circle cx="25" cy="25" r="24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.32" />
    <circle cx="25" cy="21" r="6" fill="var(--c-fern, #e0a458)" />
    <path d="M2 40 L15 26 L24 34 L34 22 L48 40 Z" fill="currentColor" opacity="0.4" />
    <path d="M2 42 L13 31 L22 38 L33 28 L48 42 Z" fill="currentColor" opacity="0.65" />
    <path d="M1 45 L12 36 L21 42 L32 34 L49 45 L49 49 L1 49 Z" fill="currentColor" />
    {showText && (
      <g>
        <text x="60" y="26" font-family="var(--font-heading)" font-size="17" font-weight="600" letter-spacing="0.14em" fill="currentColor">THE</text>
        <text x="60" y="44" font-family="var(--font-heading)" font-size="20" font-weight="600" letter-spacing="0.04em" fill="currentColor">RIDGE</text>
      </g>
    )}
  </svg>
</span>
