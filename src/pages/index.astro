---
// Home, the front door of Our Ridge. Tracks where we're at in forming a
// resident-led association, and pulls the latest news from the content
// collection, degrading gracefully when it's empty.
import BaseLayout from '../layouts/BaseLayout.astro';
import RidgeMark from '../components/RidgeMark.astro';
import NewsCard from '../components/NewsCard.astro';
import SignupForm from '../components/SignupForm.astro';
import { getCollection } from 'astro:content';

const latestNews = (await getCollection('news', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---
<BaseLayout title="Home">
  <!-- Hero -->
  <section class="section">
    <div class="container">
      <div class="panel-forest hero">
        <RidgeMark variant="light" height={56} class="hero-mark" />
        <h1>Building Our Ridge Neighbourhood Association Together</h1>
        <p class="hero-lead">
          We're in the early stages of forming a resident‑led association to
          strengthen connection and advocacy in the Ridge.
        </p>
        <div class="hero-ctas">
          <a class="btn btn-primary" href="/add-household">Add your household</a>
          <a class="btn btn-ghost" href="/get-involved">Get involved</a>
        </div>
      </div>
    </div>
  </section>

  <!-- About this effort -->
  <section class="section">
    <div class="container container-narrow prose">
      <p class="eyebrow">About this effort</p>
      <h2 class="section-title">Connecting neighbours and strengthening our voice with the City of Courtenay</h2>
      <p class="lead">
        This effort aims to build stronger connections among Our Ridge
        residents and create a clear, organized way to advocate with the City
        on issues that affect our neighbourhood.
      </p>
      <h3>A resident‑led initiative, working toward formal recognition</h3>
      <p>
        This is a volunteer, non‑commercial effort led by neighbours for
        neighbours. While Ron and Sarah Taylor are coordinating things right
        now, the goal is to create a formal neighbourhood association that
        can be recognized by the City of Courtenay, with:
      </p>
      <ul>
        <li>An elected executive that meets regularly (at least once a year).</li>
        <li>
          A clear membership structure and the ability to share approximate
          membership numbers.
        </li>
        <li>An annual general meeting (AGM) with recorded minutes.</li>
        <li>
          Demonstrated member engagement before submitting responses on
          development referrals, Official Community Plan (OCP) updates, or
          rezoning applications.
        </li>
      </ul>
    </div>
  </section>

  <!-- Where we're at -->
  <section class="section" style="padding-top:0;">
    <div class="container">
      <p class="eyebrow">Where we're at</p>
      <h2 class="section-title">Our progress so far</h2>
      <p class="lead">
        We're building this step by step. Here's where each part of the
        process stands right now:
      </p>
      <ol class="steps">
        <li class="step">
          <span class="step-num">1</span>
          <div class="step-body">
            <p class="step-title">Establish a founding group</p>
            <span class="status status-active">In progress</span>
          </div>
        </li>
        <li class="step">
          <span class="step-num">2</span>
          <div class="step-body">
            <p class="step-title">Draft purpose, values, and bylaws</p>
            <span class="status status-active">In progress</span>
          </div>
        </li>
        <li class="step">
          <span class="step-num">3</span>
          <div class="step-body">
            <p class="step-title">Collect initial member sign‑ups and contact info</p>
            <span class="status status-active">Happening now</span>
            <p class="step-action"><a href="/add-household">Add your household →</a></p>
          </div>
        </li>
        <li class="step">
          <span class="step-num">4</span>
          <div class="step-body">
            <p class="step-title">Elect an interim board and roles</p>
            <span class="status status-watching">Upcoming</span>
          </div>
        </li>
        <li class="step">
          <span class="step-num">5</span>
          <div class="step-body">
            <p class="step-title">Launch regular meetings and working groups</p>
            <span class="status status-watching">Upcoming</span>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- Latest news -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">From the Ridge</p>
      <h2 class="section-title">Latest news</h2>
      {latestNews.length > 0 ? (
        <div class="grid cols-3">
          {latestNews.map((entry) => (
            <NewsCard
              href={`/news/${entry.id}`}
              title={entry.data.title}
              date={entry.data.date}
              category={entry.data.category}
              summary={entry.data.summary}
              image={entry.data.image}
              imageAlt={entry.data.imageAlt}
            />
          ))}
        </div>
      ) : (
        <div class="card card--pad-lg">
          <p class="muted" style="margin:0">
            No posts yet, announcements, updates and vision pieces will land here.
          </p>
        </div>
      )}
      <p class="more-link"><a href="/news">All news →</a></p>
    </div>
  </section>

  <!-- New to the Ridge strip -->
  <section class="section">
    <div class="container">
      <div class="panel cta-strip">
        <div>
          <h2 class="section-title">New to the Ridge?</h2>
          <p class="muted" style="margin:0">
            Just moved in, or want to lend a hand? Here's the friendly way to get oriented and get involved.
          </p>
        </div>
        <a class="btn btn-primary" href="/get-involved">Start here</a>
      </div>
    </div>
  </section>

  <!-- Signup -->
  <section class="section">
    <div class="container">
      <SignupForm variant="panel" source="home" />
      <p class="form-note" style="margin-top:var(--space-2)">
        Not online much, or want to sign up a neighbour? Grab the <a href="/outreach">printable outreach kit</a>, a paper sign-up sheet and flyer you can hand out door to door.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: left;
    min-height: 460px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-6) var(--space-5);
    background:
      linear-gradient(180deg, rgba(18, 20, 17, 0.24) 0%, rgba(18, 20, 17, 0.52) 55%, rgba(18, 20, 17, 0.74) 100%),
      url('/img/ridge-sunset.jpg') center 58% / cover no-repeat;
  }
  .hero-mark { margin-bottom: var(--space-3); }
  .hero h1 { max-width: 20ch; margin-bottom: var(--space-2); text-shadow: 0 1px 14px rgba(0, 0, 0, 0.45); }
  .hero-lead { font-size: var(--fs-lg); max-width: 54ch; color: #f2f1ea; margin-bottom: var(--space-3); text-shadow: 0 1px 10px rgba(0, 0, 0, 0.5); }
  .hero-ctas { display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .more-link { margin-top: var(--space-3); font-weight: 600; }
  .steps { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-4); }
  .step { display: flex; gap: var(--space-3); align-items: flex-start; }
  .step-num {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    background: var(--c-forest);
    color: #fff;
    font-weight: 700;
  }
  .step-title { font-weight: 600; margin: 0 0 0.3rem; }
  .step-action { margin: 0.4rem 0 0; }
  .cta-strip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .cta-strip .btn { flex: 0 0 auto; }
</style>
