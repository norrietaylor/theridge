---
// Add your household, a short sign-up for the founding membership list as we
// build toward a formal Ridge Neighbourhood Association. Same email-fallback
// + honeypot pattern as Contact and Get Involved.
import BaseLayout from '../layouts/BaseLayout.astro';
import RidgeMark from '../components/RidgeMark.astro';
import Turnstile from '../components/Turnstile.astro';
import { SITE } from '../consts';

const mailto = `mailto:${SITE.email}?subject=${encodeURIComponent('Add our household to Our Ridge')}&body=${encodeURIComponent('Name:\nAddress:\nEmail:\n')}`;
---
<BaseLayout
  title="Add your household"
  description="Sign your household up as we build the Ridge Neighbourhood Association, just your name, address and email."
>
  <section class="section">
    <div class="container container-narrow">
      <RidgeMark height={48} class="household-mark" />
      <p class="eyebrow">Add your household</p>
      <h1>Sign your household up</h1>
      <p class="lead">
        We're collecting names, addresses and emails from interested households as
        we put the founding group and membership structure together. Add yours
        below.
      </p>

      <div class="panel email-fallback">
        <p style="margin:0">
          <strong>Prefer email?</strong> Write to <a href={mailto}>{SITE.email}</a> with your name and address.
        </p>
      </div>

      <form class="household-form" data-endpoint="/api/household" data-mailto data-to={SITE.email} data-subject="Add our household to Our Ridge" data-success="Thanks, your household is on the list. We’ll be in touch as things take shape.">
        <div class="visually-hidden" aria-hidden="true">
          <label for="h-company">Company (leave this blank)</label>
          <input id="h-company" name="company" type="text" tabindex="-1" autocomplete="off" />
        </div>
        <div class="field">
          <label for="h-name">Your name</label>
          <input id="h-name" name="name" type="text" autocomplete="name" required />
        </div>

        <div class="field">
          <label for="h-address">Home address</label>
          <input id="h-address" name="address" type="text" autocomplete="street-address" required />
        </div>

        <div class="field">
          <label for="h-email">Email address</label>
          <input id="h-email" name="email" type="email" autocomplete="email" required />
        </div>

        <Turnstile />
        <button type="submit" class="btn btn-primary">Add our household</button>
        <p class="form-note" style="margin-top:var(--space-2)">
          Prefer email? Write to <a href={mailto}>{SITE.email}</a>.
        </p>
      </form>

      <p class="household-links">
        Want to lend a hand too? See <a href="/get-involved">get involved</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .household-mark { margin-bottom: var(--space-3); }
  .email-fallback { margin-bottom: var(--space-4); border-left: 4px solid var(--c-clay); }
  .household-form { margin-top: var(--space-2); }
  .household-links { margin-top: var(--space-3); }
</style>
