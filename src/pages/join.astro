---
// Join, a short, mobile-first landing page (also the target of the QR code on
// flyers). The signup form is front and centre; everything else is reassurance.
import BaseLayout from '../layouts/BaseLayout.astro';
import RidgeMark from '../components/RidgeMark.astro';
import SignupForm from '../components/SignupForm.astro';
---
<BaseLayout
  title="Join the list"
  description="Get Ridge news, events, and a say in our neighbourhood, join the mailing list. Run by neighbours, no spam, unsubscribe anytime."
>
  <section class="section">
    <div class="container container-narrow join">
      <RidgeMark height={48} class="join-mark" />
      <p class="eyebrow">Join the list</p>
      <h1>Get Ridge news, events, and a say in our neighbourhood.</h1>
      <p class="lead">
        One friendly email now and then, what's coming up, and the issues before
        the City. Add your name below.
      </p>

      <SignupForm variant="panel" source="join" />

      <ul class="reassure">
        <li>Run by neighbours here on the Ridge</li>
        <li>No spam, ever, just the occasional useful note</li>
        <li>Unsubscribe anytime, no hard feelings</li>
      </ul>

      <p class="form-note">
        Prefer paper? Grab the <a href="/outreach">printable sign-up sheet</a>, 
        handy for neighbours who'd rather not do it online.
      </p>

      <p class="join-links">
        New here? Read <a href="/about">about the Ridge</a>, or see how we handle
        your details in our <a href="/privacy">privacy note</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .join-mark { margin-bottom: var(--space-3); }
  .join h1 { font-size: var(--fs-2xl); }
  .join .lead { margin-bottom: var(--space-4); }
  .reassure {
    list-style: none;
    padding: 0;
    margin: var(--space-4) 0 var(--space-3);
  }
  .reassure li {
    padding-left: 1.9rem;
    position: relative;
    margin-bottom: var(--space-2);
  }
  .reassure li::before {
    content: '✓';
    position: absolute;
    left: 0;
    top: 0;
    color: var(--c-forest);
    font-weight: 700;
  }
  .join-links { margin-top: var(--space-3); }
</style>
