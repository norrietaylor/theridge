---
// Contact — a branded form that posts to /api/contact once that endpoint is
// wired. Until then, a prominent email fallback keeps neighbours from hitting a
// dead end. Includes a visually-hidden honeypot ("company") to deter bots.
import BaseLayout from '../layouts/BaseLayout.astro';
import Turnstile from '../components/Turnstile.astro';
import { SITE } from '../consts';

const mailto = `mailto:${SITE.email}?subject=${encodeURIComponent('Message for The Ridge')}`;
---
<BaseLayout
  title="Contact"
  description="Get in touch with the neighbours behind The Ridge — questions about events, the voice to the City, or anything else."
>
  <section class="section">
    <div class="container container-narrow">
      <p class="eyebrow">Contact</p>
      <h1>Get in touch</h1>
      <p class="lead">
        Questions, ideas, or something you'd like us to raise? Drop us a line —
        real neighbours read every message.
      </p>

      <div class="panel email-fallback">
        <p style="margin:0">
          <strong>Prefer email?</strong> Write to
          <a href={mailto}>{SITE.email}</a> — it comes straight to the group inbox.
        </p>
      </div>

      <form class="contact-form" data-endpoint="/api/contact" data-mailto data-to={SITE.email} data-subject="Message for The Ridge" data-success="Thanks — your message is on its way. We’ll be in touch soon.">
        <div class="visually-hidden" aria-hidden="true">
          <label for="c-company">Company (leave this blank)</label>
          <input id="c-company" name="company" type="text" tabindex="-1" autocomplete="off" />
        </div>
        <div class="field">
          <label for="c-name">Your name</label>
          <input id="c-name" name="name" type="text" autocomplete="name" required />
        </div>

        <div class="field">
          <label for="c-email">Email address</label>
          <input id="c-email" name="email" type="email" autocomplete="email" required />
        </div>

        <div class="field">
          <label for="c-topic">What's it about?</label>
          <select id="c-topic" name="topic">
            <option value="events">Events &amp; community</option>
            <option value="voice">Voice to the City</option>
            <option value="general">General</option>
          </select>
        </div>

        <div class="field">
          <label for="c-message">Message</label>
          <textarea id="c-message" name="message" required></textarea>
        </div>

        <Turnstile />
        <button type="submit" class="btn btn-primary">Send message</button>
        <p class="form-note" style="margin-top:var(--space-2)">
          Real neighbours read every message. Prefer email? Write to <a href={mailto}>{SITE.email}</a>.
        </p>
      </form>
    </div>
  </section>

  <!-- Who to reach for what -->
  <section class="section-sm">
    <div class="container container-narrow">
      <h2>Who to reach for what</h2>
      <ul class="who-list">
        <li><strong>Events &amp; community</strong> — walks, rides, get-togethers, or an idea for something new.</li>
        <li><strong>Voice to the City</strong> — an issue you'd like the neighbourhood to follow, or to help with a submission.</li>
        <li><strong>General</strong> — anything else, including helping out or fixing something on this site.</li>
      </ul>
      <p class="muted">
        Want to pitch in more regularly? See <a href="/get-involved">get involved</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .email-fallback { margin-bottom: var(--space-4); border-left: 4px solid var(--c-clay); }
  .contact-form { margin-top: var(--space-2); }
  .who-list { list-style: none; padding: 0; }
  .who-list li { margin-bottom: var(--space-2); }
</style>
