---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { formatLong } from '../../lib/dates';

export async function getStaticPaths() {
  const items = await getCollection('positions');
  return items.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);

const statusClass = (status: string) =>
  status === 'Active' ? 'status-active' : status === 'Resolved' ? 'status-resolved' : 'status-watching';
---
<BaseLayout title={data.title} description={data.summary}>
  <section class="section">
    <div class="container container-narrow">
      <p class="back"><a href="/voice">← All issues</a></p>

      <article class="stack">
        <header class="issue-head">
          <div class="issue-meta">
            <span class={`status ${statusClass(data.status)}`}>{data.status}</span>
            <time class="muted" datetime={data.updated.toISOString()}>Updated {formatLong(data.updated)}</time>
          </div>
          <h1>{data.title}</h1>
          {data.summary && <p class="lead">{data.summary}</p>}
        </header>

        <div class="prose">
          <Content />
        </div>

        {data.whatYouCanDo && data.whatYouCanDo.length > 0 && (
          <div class="panel do-panel stack">
            <h2>What you can do</h2>
            <ul class="do-actions">
              {data.whatYouCanDo.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        )}
      </article>

      <div class="panel-forest issue-cta">
        <div>
          <h2>Add your voice</h2>
          <p>Join the list to hear about this issue in time to weigh in, or get in touch if you'd like to help shape what we ask the City.</p>
        </div>
        <div class="cta-actions">
          <a class="btn btn-ghost" href="/join">Join the list</a>
          <a class="btn btn-ghost" href="/contact">Get in touch</a>
        </div>
      </div>

      <p class="back back-bottom"><a href="/voice">← Back to Voice to the City</a></p>
    </div>
  </section>
</BaseLayout>

<style>
  .back { font-weight: 600; font-size: var(--fs-sm); margin-bottom: var(--space-3); }
  .back-bottom { margin-top: var(--space-4); }
  .issue-head { margin-bottom: var(--space-2); }
  .issue-meta { display: flex; align-items: center; gap: var(--space-2); flex-wrap: wrap; margin-bottom: var(--space-2); }
  .issue-head h1 { margin-bottom: var(--space-1); }

  .do-panel { margin-top: var(--space-4); border-left: 4px solid var(--c-clay); }
  .do-panel h2 { margin-bottom: 0; }
  .do-actions { margin: 0; }

  .issue-cta {
    margin-top: var(--space-5);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .issue-cta h2 { margin-bottom: var(--space-1); }
  .issue-cta p { margin: 0; color: #e7ded0; max-width: 46ch; }
  .cta-actions { display: flex; gap: var(--space-2); flex-wrap: wrap; }
</style>
