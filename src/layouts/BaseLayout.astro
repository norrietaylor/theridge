---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MailtoForm from '../components/MailtoForm.astro';
import { SITE } from '../consts';

interface Props {
  title?: string;
  description?: string;
  /** Absolute or root-relative path to a social share image (optional). */
  image?: string;
}
const {
  title,
  description = 'The community website for The Ridge in South Courtenay, BC — events, neighbours, and a shared voice with the City.',
  image,
} = Astro.props;

const pageTitle = title ? `${title} · ${SITE.name}` : `${SITE.name} · ${SITE.tagline}`;
const canonical = new URL(Astro.url.pathname, SITE.url).href;
const ogImage = image ? new URL(image, SITE.url).href : undefined;
const turnstileKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---
<!doctype html>
<html lang="en-CA">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      /* Apply the saved theme + light/dark mode before paint (no flash). */
      (function () {
        try {
          var r = document.documentElement;
          var t = localStorage.getItem('ridge-theme');
          var m = localStorage.getItem('ridge-mode');
          r.dataset.theme = t === 'coastal' || t === 'modern' || t === 'editorial' ? t : 'natural';
          if (m !== 'light' && m !== 'dark') {
            m = window.matchMedia && matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          r.dataset.mode = m;
        } catch (e) {
          document.documentElement.dataset.theme = 'natural';
          document.documentElement.dataset.mode = 'light';
        }
      })();
    </script>
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    {turnstileKey && <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>}
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <MailtoForm />
  </body>
</html>
